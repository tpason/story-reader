# Copy to .env.local for local dev: cp .env.example .env.local

# Canonical public origin — used for metadataBase, OG/Twitter image URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Realtime WebSocket (requires npm run dev:ws or npm run start:ws, not plain next dev).
# Generate token: bash ../docker/scripts/generate-reader-realtime-token.sh
# Leave empty for local dev without auth; set when testing broadcast auth or matching Docker.
# READER_REALTIME_TOKEN=
# Optional: explicit WS URL (default: same host as page → /reader-ws).
# NEXT_PUBLIC_READER_WS_URL=
