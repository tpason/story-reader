{
  "name": "story-reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ws": "node server.js",
    "dev:lan": "next dev -H 0.0.0.0 -p ${PORT:-3000}",
    "build": "next build --experimental-debug-memory-usage",
    "format:reader-content": "npx tsc scripts/backfill-reader-formatted-content.ts lib/formatNovelContent.ts --outDir .cache/reader-format-job --module commonjs --target ES2022 --moduleResolution node --esModuleInterop --skipLibCheck && node .cache/reader-format-job/scripts/backfill-reader-formatted-content.js",
    "start": "next start",
    "start:ws": "NODE_ENV=production node server.js",
    "start:lan": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "tunnel": "ngrok http ${PORT:-3000}",
    "lint": "next lint",
    "test:unit": "node --experimental-strip-types --test tests/*.test.ts",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.25",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/web-push": "^3.6.4",
    "animejs": "^4.4.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "fuse.js": "^7.3.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.468.0",
    "media-chrome": "^4.19.0",
    "next": "^15.1.3",
    "pg": "^8.13.1",
    "postprocessing": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "three": "^0.184.0",
    "typescript": "^5.7.2",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@types/pg": "^8.11.10",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3"
  }
}
