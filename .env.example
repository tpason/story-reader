# Copy to .env.local for local dev (optional — dev-story-reader.sh loads root .env too)
#   cp .env.example .env.local

STORY_DATABASE_URL=postgresql://betterbox:betterbox@127.0.0.1:54329/betterbox_story

# Public origin (OG/Twitter absolute URLs, sitemap, JSON-LD). Production: https://linhquyen.cc
# NEXT_PUBLIC_SITE_URL=https://linhquyen.cc

# Production secrets (generate once, paste into root .env — do not commit):
#   bash ../docker/scripts/generate-reader-realtime-token.sh
#   bash ../docker/scripts/generate-vapid-keys.sh
# READER_REALTIME_TOKEN=          # required in production (broadcast API)
# PUSH_SEND_SECRET=               # optional direct push API; broadcast path is preferred
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Disable public signup on production reader (admin accounts created via story_admin)
# READER_SIGNUP_DISABLED=1

# Transactional email (Resend prod, SMTP dev/fallback)
# RESEND_API_KEY=
# MAIL_FROM="Linh Quyển Các <noreply@linhquyen.cc>"
# SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASS= SMTP_SECURE=0
# MAIL_LOG_ONLY=1
# MAIL_DIGEST_CRON_TOKEN=
# EMAIL_DIGEST_INTERVAL_SECONDS=604800

# Web Push — register /sw.js in dev:ws (needs VAPID keys)
# NEXT_PUBLIC_ENABLE_PWA=1

# Default dev port (docker/scripts/dev-story-reader.sh uses 3003)
# PORT=3003

# Optional: raise MyMemory EN→VI gloss quota for /api/reader/lookup (valid email)
# LOOKUP_MYMEMORY_EMAIL=you@example.com
